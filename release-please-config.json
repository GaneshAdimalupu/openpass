{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "packages": {
    "apps/web": {
      "release-type": "node",
      "package-name": "@openpass/web"
    },
    "apps/api": {
      "release-type": "node",
      "package-name": "@openpass/api"
    },
    "packages/core": {
      "release-type": "node",
      "package-name": "@openpass/core"
    },
    "packages/db": {
      "release-type": "node",
      "package-name": "@openpass/db"
    },
    "packages/ui": {
      "release-type": "node",
      "package-name": "@openpass/ui"
    },
    "packages/types": {
      "release-type": "node",
      "package-name": "@openpass/types"
    },
    "packages/typescript-config": {
      "release-type": "node",
      "package-name": "@openpass/typescript-config"
    },
    "packages/eslint-config": {
      "release-type": "node",
      "package-name": "@openpass/eslint-config"
    },
    "packages/prettier-config": {
      "release-type": "node",
      "package-name": "@openpass/prettier-config"
    },
    "packages/commitlint-config": {
      "release-type": "node",
      "package-name": "@openpass/commitlint-config"
    }
  },
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "changelog-sections": [
    { "type": "feat", "section": "✨ Features" },
    { "type": "fix", "section": "🐛 Bug Fixes" },
    { "type": "perf", "section": "⚡ Performance" },
    { "type": "refactor", "section": "♻️  Refactor" },
    { "type": "docs", "section": "📖 Documentation" },
    { "type": "ci", "section": "👷 CI/CD" },
    { "type": "chore", "section": "🔧 Miscellaneous", "hidden": false }
  ]
}
